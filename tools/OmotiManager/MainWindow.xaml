<Window x:Class="OmotiManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Omoti Manager"
        Height="780"
        Width="1180"
        MinHeight="700"
        MinWidth="1020"
        Background="#07101A"
        Foreground="#F5F7FB"
        FontFamily="Yu Gothic UI">
    <Window.Resources>
        <LinearGradientBrush x:Key="Bg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#08111D" Offset="0"/>
            <GradientStop Color="#0B1A2F" Offset="0.55"/>
            <GradientStop Color="#08111D" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#CC0C1728"/>
            <Setter Property="BorderBrush" Value="#2E4B6B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="18"/>
        </Style>
        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#F7FBFF"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#09131F"/>
            <Setter Property="Foreground" Value="#EEF5FF"/>
            <Setter Property="BorderBrush" Value="#29405A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="Primary" TargetType="Button">
            <Setter Property="Background" Value="#58A6FF"/>
            <Setter Property="Foreground" Value="#F9FBFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Ghost" TargetType="Button" BasedOn="{StaticResource Primary}">
            <Setter Property="Background" Value="#1C2B41"/>
        </Style>
        <Style x:Key="Danger" TargetType="Button" BasedOn="{StaticResource Primary}">
            <Setter Property="Background" Value="#4A2230"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource Bg}">
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Omoti Manager" FontFamily="Bahnschrift SemiBold" FontSize="30"/>
                    <TextBlock Margin="0,6,0,0" Foreground="#9EB0C8" Text="Music list and YouTube import only."/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Open Music Folder" Margin="0,0,10,0" Style="{StaticResource Ghost}" Click="OpenMusicFolderButton_Click"/>
                    <Button Content="Open Root" Style="{StaticResource Ghost}" Click="OpenRootFolderButton_Click"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,18,0">
                        <TextBlock Text="YouTube Import" Style="{StaticResource TitleText}"/>
                        <TextBlock Margin="0,6,0,14" Foreground="#9EB0C8" Text="Paste a link and convert the result to mp3."/>
                        <TextBox x:Name="UrlTextBox" Height="42" Style="{StaticResource Input}" VerticalContentAlignment="Center"/>
                        <WrapPanel Margin="0,14,0,0">
                            <CheckBox x:Name="AllowPlaylistCheckBox" Margin="0,0,16,10" VerticalAlignment="Center" Content="Allow playlist" Foreground="#EEF4FF"/>
                            <Button x:Name="DownloadButton" Content="Download MP3" Margin="0,0,10,10" Style="{StaticResource Primary}" Click="DownloadButton_Click"/>
                            <Button x:Name="ClearUrlButton" Content="Clear" Margin="0,0,10,10" Style="{StaticResource Ghost}" Click="ClearUrlButton_Click"/>
                        </WrapPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#101A29" BorderBrush="#29405A" BorderThickness="1" CornerRadius="16" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Status" Foreground="#9EB0C8"/>
                            <TextBlock x:Name="DownloadStateTextBlock" Margin="0,8,0,8" FontFamily="Bahnschrift SemiBold" FontSize="24" Text="Ready"/>
                            <TextBlock x:Name="DownloadHintTextBlock" Foreground="#C9D6E8" TextWrapping="Wrap" Text="Paste a URL to start."/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Music List" Style="{StaticResource TitleText}"/>
                            <TextBlock x:Name="TrackCountValueTextBlock" Margin="0,6,0,0" Foreground="#9EB0C8" Text="0 tracks"/>
                        </StackPanel>
                        <TextBox x:Name="LibrarySearchTextBox" Grid.Column="1" Height="42" Style="{StaticResource Input}" VerticalContentAlignment="Center" TextChanged="LibrarySearchTextBox_TextChanged"/>
                        <WrapPanel Grid.Column="2" Margin="14,0,0,0">
                            <Button Content="Add" Margin="0,0,10,0" Style="{StaticResource Ghost}" Click="ImportFilesButton_Click"/>
                            <Button x:Name="DeleteSelectedButton" Content="Delete" Margin="0,0,10,0" Style="{StaticResource Danger}" Click="DeleteSelectedButton_Click"/>
                            <Button x:Name="RefreshLibraryButton" Content="Refresh" Style="{StaticResource Ghost}" Click="RefreshLibraryButton_Click"/>
                        </WrapPanel>
                    </Grid>
                    <ListView x:Name="LibraryListView" Grid.Row="2" MouseDoubleClick="LibraryListView_MouseDoubleClick" Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="Background" Value="#101B2B"/>
                                <Setter Property="BorderBrush" Value="#21344C"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView AllowsColumnReorder="False">
                                <GridViewColumn Header="Title" Width="430" DisplayMemberBinding="{Binding Title}"/>
                                <GridViewColumn Header="File" Width="280" DisplayMemberBinding="{Binding FileName}"/>
                                <GridViewColumn Header="Type" Width="80" DisplayMemberBinding="{Binding Extension}"/>
                                <GridViewColumn Header="Size" Width="100" DisplayMemberBinding="{Binding SizeLabel}"/>
                                <GridViewColumn Header="Modified" Width="170" DisplayMemberBinding="{Binding ModifiedLabel}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Row="5" Margin="0,18,0,0" Background="#0A1320" BorderBrush="#22364E" BorderThickness="1" CornerRadius="14" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PipelineDetailTextBlock" Foreground="#9EB0C8" Text="Ready" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="1" x:Name="StorageValueTextBlock" Foreground="#9EB0C8" Text="0 MB"/>
                </Grid>
            </Border>

            <TextBlock x:Name="PipelineValueTextBlock" Visibility="Collapsed"/>
            <TextBlock x:Name="RootFolderTextBlock" Visibility="Collapsed"/>
            <TextBlock x:Name="MusicFolderTextBlock" Visibility="Collapsed"/>
            <TextBox x:Name="YtDlpPathTextBox" Visibility="Collapsed"/>
            <TextBox x:Name="FfmpegPathTextBox" Visibility="Collapsed"/>
            <TextBox x:Name="LogTextBox" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
